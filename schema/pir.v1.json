{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signetry.ai/records/schema.json",
  "title": "PIR Product Record",
  "description": "Signetry Product Intelligence Record — structured product facts indexed by GTIN.",
  "type": "object",
  "required": ["schema", "gtin", "sku", "brand", "name", "category", "status", "facts"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "pir/1.0"
    },
    "gtin": {
      "description": "EAN-13 barcode number. Null if pending.",
      "type": ["string", "null"]
    },
    "sku": {
      "type": "string",
      "description": "Manufacturer SKU or model number."
    },
    "brand": {
      "type": "string",
      "description": "Brand name as sold. For wrapped products this is the manufacturer brand."
    },
    "manufacturer": {
      "type": "string",
      "description": "Actual manufacturer, if different from brand."
    },
    "range": {
      "type": "string",
      "description": "Product range or series within the brand."
    },
    "name": {
      "type": "string",
      "description": "Human-readable product name."
    },
    "category": {
      "type": "string",
      "description": "Product category.",
      "enum": [
        "bar_fridge",
        "wine_fridge",
        "wine_cellar",
        "beverage_fridge",
        "commercial_fridge",
        "integrated_fridge",
        "portable_fridge",
        "upright_display_fridge",
        "open_display_cooler",
        "freezer"
      ]
    },
    "base_model": {
      "type": "string",
      "description": "Base platform model for branded/wrapped variants."
    },
    "branding": {
      "type": "object",
      "description": "Branding metadata for wrapped/OEM/sub-brand products.",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["licensed_wrap", "sub_brand", "oem", "house_brand"]
        },
        "wrap_brand": { "type": "string" },
        "licensor": { "type": "string" },
        "sub_brand": { "type": "string" },
        "original_brand": { "type": "string" }
      },
      "required": ["type"]
    },
    "status": {
      "type": "object",
      "required": ["brand_certified"],
      "properties": {
        "brand_certified": {
          "type": "boolean",
          "description": "True if the brand has verified this record via DNS domain ownership."
        },
        "brand_domain": {
          "type": ["string", "null"],
          "description": "Brand's verified domain."
        },
        "certified_date": {
          "type": ["string", "null"],
          "format": "date"
        },
        "submitted_by": {
          "type": "string",
          "description": "Domain of the contributor who submitted this record."
        },
        "submitted_date": {
          "type": ["string", "null"],
          "format": "date"
        }
      }
    },
    "facts": {
      "type": "object",
      "description": "Structured product specifications. Keys use unit-in-name convention (e.g. capacity_litres, weight_kg).",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" },
          { "type": "array", "items": { "type": "string" } }
        ]
      }
    },
    "notes": {
      "type": "array",
      "description": "Expert-verified prose that elaborates on or qualifies atomic facts. Each note is topic-scoped and linked to the facts it explains.",
      "items": {
        "type": "object",
        "required": ["topic", "text", "facts"],
        "properties": {
          "topic": {
            "type": "string",
            "description": "Semantic topic tag for resolver matching.",
            "enum": [
              "power_consumption",
              "temperature_control",
              "shelving",
              "installation",
              "components",
              "door_configuration",
              "glass",
              "noise",
              "warranty",
              "capacity",
              "location_suitability",
              "maintenance"
            ]
          },
          "text": {
            "type": "string",
            "description": "Verified prose. Expert voice, no marketing language."
          },
          "facts": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Fact keys this note elaborates on. Establishes provenance."
          }
        }
      }
    },
    "qa": {
      "type": "array",
      "description": "Pre-answered questions with fact citations.",
      "items": {
        "type": "object",
        "required": ["q", "a", "facts"],
        "properties": {
          "q": { "type": "string", "description": "Question text." },
          "a": { "type": "string", "description": "Answer text." },
          "facts": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of fact keys that support this answer."
          }
        }
      }
    },
    "documents": {
      "type": "array",
      "description": "Links to spec sheets, manuals, brochures.",
      "items": {
        "type": "object",
        "required": ["type", "url"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["spec_sheet", "manual", "brochure", "datasheet", "installation_guide"]
          },
          "url": { "type": "string", "format": "uri" },
          "source": { "type": "string" },
          "brand_certified": { "type": "boolean" }
        }
      }
    },
    "sellers": {
      "type": "array",
      "description": "Authorized and known sellers.",
      "items": {
        "type": "object",
        "required": ["name", "domain"],
        "properties": {
          "name": { "type": "string" },
          "domain": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "authorized": { "type": "boolean" },
          "regions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
